{
  "rules": {
    "rooms": {
      "$roomId": {
        // Читати кімнату можуть всі (для перегляду чужої обстановки)
        ".read": true,

        "users": {
          "$uid": {
            // Писати в свій запис може будь-хто
            // (авторизація відбувається через UID який зберігається локально)
            ".write": true,

            // Валідація структури даних — захист від сміттєвих записів
            ".validate": "newData.hasChildren(['uid','ts','items']) && newData.child('ts').isNumber() && newData.child('uid').isString()",

            "items": {
              "$itemId": {
                ".validate": "newData.hasChildren(['lat','lng','type']) && newData.child('lat').isNumber() && newData.child('lng').isNumber() && newData.child('lat').val() >= -90 && newData.child('lat').val() <= 90 && newData.child('lng').val() >= -180 && newData.child('lng').val() <= 180"
              }
            }
          }
        }
      }
    },

    // Заборонити будь-який доступ до решти бази
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
