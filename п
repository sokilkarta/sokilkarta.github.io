// ISKANDER PRECISE CALCULATOR v23
(function(){
  const table = {"50": 43.81, "100": 67.62, "120": 77.14, "140": 86.67, "160": 96.19, "180": 105.71, "200": 115.24, "220": 124.76, "240": 134.29, "260": 143.81, "280": 153.33, "300": 162.86, "320": 172.38, "340": 181.9, "360": 191.43, "380": 200.95, "400": 210.48, "420": 220.0, "440": 229.52, "460": 239.05, "480": 248.57, "500": 258.1};
  const keys = Object.keys(table).map(k=>parseFloat(k)).sort((a,b)=>a-b);

  function interpolate(d){
    if(d<=keys[0]) return table[keys[0]];
    if(d>=keys[keys.length-1]) return table[keys[keys.length-1]];
    for(let i=0;i<keys.length-1;i++){
      const a=keys[i], b=keys[i+1];
      if(d>=a && d<=b){
        const ta=table[a], tb=table[b];
        return ta + (d-a)/(b-a)*(tb-ta);
      }
    }
    return null;
  }

  const btn=document.getElementById('iskCalcBtn');
  let mode=false;
  if(btn){
    btn.addEventListener('click',()=>{
      mode=!mode;
      btn.classList.toggle('active',mode);
    });
  }

  map.on('click',e=>{
    if(!mode) return;
    let nearest=null, nd=1e9;
    for(const it of state.items.values()){
      if(!it||!it.type) continue;
      if(String(it.type).includes('iskander')){
        const d=map.distance(it.marker.getLatLng(),e.latlng)/1000;
        if(d<nd){ nd=d; nearest=it; }
      }
    }
    if(!nearest){
      L.popup().setLatLng(e.latlng).setContent('Не знайдено Іскандера.').openOn(map);
      mode=false; if(btn) btn.classList.remove('active');
      return;
    }
    const t=interpolate(nd);
    const mins=Math.floor(t/60);
    const secs=Math.round(t%60);
    const msg=`Відстань: ${nd.toFixed(2)} km<br>Час (приблизно): ${mins}m ${secs}s (${t.toFixed(1)} s)`;
    L.popup().setLatLng(e.latlng).setContent(msg).openOn(map);
    mode=false; if(btn) btn.classList.remove('active');
  });
})();
