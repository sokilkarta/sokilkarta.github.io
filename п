let isRMB=false, startPoint=null, selectionRect=null;
let selectedItems = new Set();

map.getContainer().addEventListener("contextmenu", e => e.preventDefault());

// лкм — очищення виділення
map.on("click", () => {
  for (const item of selectedItems) {
    if (item.marker._icon) item.marker._icon.classList.remove("marker-selected");
  }
  selectedItems.clear();
  document.getElementById('selectedId').textContent = '—';
});

map.on("mousedown", e => {
  if (e.originalEvent.button === 2) {
    isRMB = true;
    startPoint = map.latLngToContainerPoint(e.latlng);
    selectionRect = L.DomUtil.create("div", "selection-rect", document.body);
    selectionRect.style.left = startPoint.x + "px";
    selectionRect.style.top = startPoint.y + "px";
    selectionRect.style.width = "0px";
    selectionRect.style.height = "0px";
  }
});

map.on("mousemove", e => {
  if (!isRMB || !selectionRect) return;
  const cur = map.latLngToContainerPoint(e.latlng);
  const x1 = Math.min(startPoint.x, cur.x);
  const y1 = Math.min(startPoint.y, cur.y);
  const x2 = Math.max(startPoint.x, cur.x);
  const y2 = Math.max(startPoint.y, cur.y);
  selectionRect.style.left = x1 + "px";
  selectionRect.style.top = y1 + "px";
  selectionRect.style.width = (x2 - x1) + "px";
  selectionRect.style.height = (y2 - y1) + "px";
});

map.on("mouseup", e => {
  if (e.originalEvent.button !== 2) return;
  isRMB = false;

  if (!selectionRect) return;

  const rect = selectionRect.getBoundingClientRect();
  selectionRect.remove();
  selectionRect = null;

  // очистити попереднє виділення
  for (const item of selectedItems) {
    if (item.marker._icon) item.marker._icon.classList.remove("marker-selected");
  }
  selectedItems.clear();

  // знайти нові виділені
  for (const item of state.items.values()) {
    const pt = map.latLngToContainerPoint(item.marker.getLatLng());
    if (pt.x >= rect.left && pt.x <= rect.right &&
        pt.y >= rect.top && pt.y <= rect.bottom) {
      selectedItems.add(item);
      if (item.marker._icon) item.marker._icon.classList.add("marker-selected");
    }
  }

  // Оновити показ обраного
  if (selectedItems.size === 1) {
    const only = [...selectedItems][0];
    document.getElementById('selectedId').textContent = only.id;
    state.selected = only;
  } else if (selectedItems.size > 1) {
    document.getElementById('selectedId').textContent = "група (" + selectedItems.size + ")";
    state.selected = null;
  }
});

// Кнопка Видалити — видаляє або 1 або групу
const oldDelete = deleteBtn.onclick;
deleteBtn.onclick = () => {
  if (selectedItems.size > 0) {
    for (const item of selectedItems) {
      map.removeLayer(item.marker);
      if (item.arrowLine) map.removeLayer(item.arrowLine);
      if (item.decorator) map.removeLayer(item.decorator);
      if (item.label) map.removeLayer(item.label);
      state.items.delete(item.id);
    }
    selectedItems.clear();
    document.getElementById('selectedId').textContent = '—';
    state.selected = null;
  } else {
    oldDelete();
  }
};


