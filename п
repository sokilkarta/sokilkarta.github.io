<script>
(function(){
  // Calculator mode for Iskander flight time (linear model: 500 km -> 238 s)
  let iskCalcMode = false;
  const CALC_LABEL = '📐 Calculator';
  const CALC_ACTIVE = '📐 Calculator (виберіть ціль)';
  function formatTimeSec(s){
    if(s<60) return Math.round(s) + ' s';
    const m = Math.floor(s/60);
    const sec = Math.round(s - m*60);
    return m + 'm ' + sec + 's';
  }
  const btn = document.getElementById('iskCalcBtn');
  if(!btn) return;
  btn.addEventListener('click', ()=>{
    iskCalcMode = !iskCalcMode;
    btn.classList.toggle('active', iskCalcMode);
    btn.textContent = iskCalcMode ? CALC_ACTIVE : CALC_LABEL;
    if(iskCalcMode){
      // temporary instruction popup
      console.log('Iskander calculator mode ON. Click on map to choose target.');
    }
  });
  // click handler on map
  function onMapClickForCalc(e){
    if(!iskCalcMode) return;
    // find nearest iskander from state.items
    let nearest = null;
    let nearestDist = Infinity;
    try{
      for(const it of state.items.values()){
        if(!it || !it.type) continue;
        if(String(it.type).indexOf('iskander')===-1) continue;
        const d = map.distance(it.marker.getLatLng(), e.latlng); // in meters
        if(d < nearestDist){ nearestDist = d; nearest = it; }
      }
    }catch(err){
      console.error('calc: state items error', err);
    }
    if(!nearest){
      L.popup({maxWidth:300}).setLatLng(e.latlng).setContent('Не знайдено Іскандера — додайте спершу.').openOn(map);
      iskCalcMode = false;
      btn.classList.remove('active');
      btn.textContent = CALC_LABEL;
      return;
    }
    const dist_km = nearestDist/1000;
    // model: T = (D_km / 500) * 238
    const time_s = (dist_km/500) * 238;
    const html = ''
               + 'Відстань: ' + dist_km.toFixed(2) + ' km<br>'
               + 'Час (приблизно): ' + formatTimeSec(time_s) + ' (' + time_s.toFixed(1) + ' s)';
    L.popup({maxWidth:320, className:'isk-calc-popup'}).setLatLng(e.latlng).setContent(html).openOn(map);
    // reset mode
    iskCalcMode = false;
    btn.classList.remove('active');
    btn.textContent = CALC_LABEL;
  }
  map.on('click', onMapClickForCalc);
})();
</script>
